      "keywords": ["挂人", "开盒", "网暴", "身份证", "手机号", "家庭住址"],
      "regex_patterns": ["身份证号|手机号|家庭住址", "(挂人|开盒|网暴)", "曝光.*(聊天记录|隐私)"],
