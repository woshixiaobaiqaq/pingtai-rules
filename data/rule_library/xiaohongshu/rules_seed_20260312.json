{
  "rules": [
    {
      "platform": "xiaohongshu",
      "rule_id": "XHS-CAT-001",
      "title": "真诚分享：虚假人设与虚构经历",
      "content": "内容应基于真实身份、真实经历和真实表达，禁止编造财富、职业、学历、情感和成长故事误导用户。",
      "source_url": "https://finance.sina.com.cn/tech/2026-01-19/doc-inhhvmxz9883989.shtml",
      "severity": "high",
      "tags": ["persona_fabrication"],
      "keywords": ["虚假人设", "逆袭故事", "编造经历", "名校毕业", "年入百万", "宝妈创业"],
      "regex_patterns": ["(月入|年入)\\d+(万|w|百万)", "前(大厂|投行|名企).*创业", "编造.*(学历|职业|经历)"],
      "metadata": {
        "source_type": "public_report_of_official_update",
        "pillar": "真诚分享",
        "source_urls": [
          "https://finance.sina.com.cn/tech/2026-01-19/doc-inhhvmxz9883989.shtml",
          "https://huacheng.gz-cmc.com/pages/2026/01/20/5b9629a5d7334c4cbcba77db98424444.html"
        ],
        "examples": ["编造财富自由和创业逆袭故事", "虚构学历、职业身份吸引关注", "伪造亲身经历包装内容可信度"]
      }
    },
    {
      "platform": "xiaohongshu",
      "rule_id": "XHS-CAT-002",
      "title": "真诚分享：AI 生成与深度合成标识",
      "content": "使用 AI 生成、深度合成或会显著影响真实性判断的内容，应明确标识，不得利用 AI 伪造证据、形象或身份。",
      "source_url": "https://finance.sina.com.cn/tech/2026-01-19/doc-inhhvmxz9883989.shtml",
      "severity": "medium",
      "tags": ["ai_generated_content", "rights_infringement"],
      "keywords": ["AI生成", "AIGC", "深度合成", "AI换脸", "数字人", "AI配音"],
      "regex_patterns": ["AI(生成|合成|换脸)", "深度合成", "数字人.*口播"],
      "metadata": {
        "source_type": "public_report_of_official_update",
        "pillar": "真诚分享",
        "source_urls": [
          "https://finance.sina.com.cn/tech/2026-01-19/doc-inhhvmxz9883989.shtml",
          "https://huacheng.gz-cmc.com/pages/2026/01/20/5b9629a5d7334c4cbcba77db98424444.html"
        ],
        "examples": ["AI 换脸伪装真人分享", "未标识 AI 生成图片或视频", "利用深度合成伪造聊天或证据"]
      }
    },
    {
      "platform": "xiaohongshu",
      "rule_id": "XHS-CAT-003",
      "title": "真诚分享：标题党与夸张误导",
      "content": "禁止使用夸张标题、虚假封面、过度修饰和误导性表述骗取点击或制造错误预期。",
      "source_url": "https://huacheng.gz-cmc.com/pages/2026/01/20/5b9629a5d7334c4cbcba77db98424444.html",
      "severity": "medium",
      "tags": ["clickbait_content"],
      "keywords": ["震惊", "一定要看完", "最后一条", "99%的人不知道", "封面即真相", "看完沉默"],
      "regex_patterns": ["\\d+%的人都不知道", "一定要看完", "最后一条.*颠覆认知"],
      "metadata": {
        "source_type": "public_report_of_official_update",
